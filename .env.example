# VigilCut — environment template (copy to .env locally; never commit secrets)

# ── Local library ──────────────────────────────────────────────────────────
# VIGILCUT_LIBRARY_ROOT=C:\path\to\test-library

# ── Image generation (OmniRoute optional) ──────────────────────────────────
# Default provider is mock when OMNIROUTE_BASE_URL is unset.
OMNIROUTE_BASE_URL=http://localhost:20128/v1
# OMNIROUTE_API_KEY=
OMNIROUTE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
OMNIROUTE_FREE_TIER=true
OMNIROUTE_TIMEOUT_SECS=90
# Force offline generator: mock | omniroute
VIGILCUT_IMAGE_PROVIDER=mock

# Pollinations is experimental, metered, and disabled by default.
# Selecting it still requires VIGILCUT_PAID_PROVIDERS=1 and the explicit
# experimental gate; it is never eligible for daily feed.
# POLLINATIONS_API_KEY=sk_...
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_TIMEOUT_SECS=90
VIGILCUT_POLLINATIONS_EXPERIMENTAL=0

# ── Cost policy (hard gates) ───────────────────────────────────────────────
VIGILCUT_PAID_PROVIDERS=0
VIGILCUT_DAILY_PAID_BUDGET=0
VIGILCUT_MAX_DAILY_GENERATIONS=20
# Opportunistic free-tier fill of priority concepts (never burn quota for fun)
VIGILCUT_OPPORTUNISTIC=0
# Require human review for AI-generated images (default true)
VIGILCUT_REQUIRE_HUMAN_QA=1

# ── Supabase (optional remote catalog — app works fully offline without) ──
VIGILCUT_SUPABASE_SYNC=0
VIGILCUT_SUPABASE_RLS_VERIFIED=0
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Per-user session access token; never service_role/secret key.
# SUPABASE_ACCESS_TOKEN=eyJ...
# SUPABASE_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# Never put service_role or sb_secret_ in the desktop client.
